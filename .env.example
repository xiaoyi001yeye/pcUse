# LLM provider. Supported MVP values: openai, openai-compatible, none
PC_USE_AGENT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local runtime
PC_USE_AGENT_HOST=127.0.0.1
PC_USE_AGENT_PORT=8765
PC_USE_AGENT_DATA_DIR=./storage

# Safety
PC_USE_AGENT_REQUIRE_CONFIRMATION=true
PC_USE_AGENT_DEFAULT_EXECUTION_MODE=structured
